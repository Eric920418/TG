# ==== Telegram ====
TELEGRAM_BOT_TOKEN=
# 自訂亂數字串 (建議 openssl rand -hex 32)，驗 webhook X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_WEBHOOK_SECRET=
# bot username (不含 @)，後台 Login Widget 用
TELEGRAM_BOT_USERNAME=

# ==== Neon Postgres ====
DATABASE_URL=

# ==== Upstash Redis ====
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==== Upstash QStash ====
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ==== iron-session ====
# 至少 32 字元，建議 openssl rand -base64 48
SESSION_PASSWORD=

# ==== Vercel Cron ====
# Vercel cron 驗 Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ==== 部署 URL ====
# 設定 webhook 用，例如 https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
