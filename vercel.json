{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/sweep",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/verification-expire",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/ensure-webhook",
      "schedule": "0 17 * * *"
    }
  ],
  "functions": {
    "src/app/api/telegram/webhook/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/send-scheduled/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/sweep/route.ts": {
      "maxDuration": 60
    }
  }
}
